DATABASE_URL=postgres://postgres:postgres@localhost:5432/gambling_dev
PORT=3000
NODE_ENV=development
JWT_SECRET=generate-with-node-e-console.log-require-crypto-.randomBytes-32-.toString-hex
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
SMTP_FROM=noreply@casino.local
FRONTEND_URL=http://localhost:5173

# Google "Sign in with Google" — the OAuth 2.0 Web client ID from
# https://console.cloud.google.com/apis/credentials (NOT a secret; safe to ship
# to the browser). Leave blank to disable Google sign-in. Authorized JavaScript
# origin must include http://localhost:5173 (and your prod URL).
GOOGLE_CLIENT_ID=
