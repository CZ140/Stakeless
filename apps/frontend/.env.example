# Frontend environment (Vite). Copy to apps/frontend/.env and fill in.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Google "Sign in with Google" client ID — the SAME OAuth 2.0 Web client ID as the
# backend's GOOGLE_CLIENT_ID. It is a public client identifier, not a secret.
# Leave blank to hide the Google sign-in button.
VITE_GOOGLE_CLIENT_ID=

# Socket.IO server URL. Leave blank for the single-origin deploy (the socket
# connects to the same origin that served the app) and for local dev (defaults to
# http://localhost:3000). Only set this when the frontend and backend are hosted
# on separate domains, e.g. VITE_SOCKET_URL=https://api.example.com
VITE_SOCKET_URL=
